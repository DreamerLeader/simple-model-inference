# 忽略 Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 忽略虚拟环境
venv/
env/
ENV/
.venv/

# 忽略 IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~

# 忽略模型文件（通常很大）
*.pt
*.pth
*.onnx
*.ckpt
*.pkl
models/
checkpoints/

# 忽略日志和输出
*.log
logs/
output/
results/

# 忽略测试覆盖率
.coverage
htmlcov/
.pytest_cache/

# 忽略 macOS 系统文件
.DS_Store

# 忽略 Jupyter Notebook 检查点
.ipynb_checkpoints/

# 忽略数据文件
data/
datasets/
*.jpg
*.jpeg
*.png
*.gif
